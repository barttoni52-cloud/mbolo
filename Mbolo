<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#009e60">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="MBOLO">
<title>MBOLO — Guide de Libreville</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:#f0f0f0;display:flex;justify-content:center;min-height:100vh;}
:root{--g:#009e60;--g2:#007a4a;--g3:#e6f7ef;--y:#fcd116;--y2:#c9a800;--y3:#fffbdd;--b:#3a75c4;--b2:#0C447C;--b3:#e8f0fb;--text:#1a1a1a;--muted:#666;--bg:#fff;--bg2:#f5f5f5;--bd:#e0e0e0;--red:#E24B4A;}
.app{width:100%;max-width:430px;background:var(--bg);min-height:100vh;display:flex;flex-direction:column;position:relative;}
.screen{display:none;flex-direction:column;flex:1;min-height:100vh;}
.screen.on{display:flex;}
.scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;}

/* SPLASH */
.splash{background:var(--g);flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 28px;min-height:100vh;}
.flag{display:flex;width:60px;height:40px;border-radius:8px;overflow:hidden;margin-bottom:20px;border:2px solid rgba(255,255,255,0.3);}
.flag div{flex:1;}
.logo-big{font-size:56px;font-weight:800;color:#fff;letter-spacing:-2px;margin-bottom:4px;}
.logo-sub{font-size:12px;color:rgba(255,255,255,0.7);letter-spacing:3px;text-transform:uppercase;margin-bottom:40px;}
.sdots{display:flex;gap:6px;margin-bottom:40px;}
.sdot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.3);}
.sdot.y{background:var(--y);}
.btn-y{width:100%;padding:16px;background:var(--y);color:#7a5c00;font-size:15px;font-weight:700;border:none;border-radius:14px;cursor:pointer;margin-bottom:10px;}
.btn-wh{width:100%;padding:15px;background:rgba(255,255,255,0.15);color:#fff;font-size:14px;font-weight:500;border:1.5px solid rgba(255,255,255,0.35);border-radius:14px;cursor:pointer;margin-bottom:10px;}
.btn-ghost{width:100%;padding:12px;background:transparent;color:rgba(255,255,255,0.65);font-size:13px;border:none;cursor:pointer;}
.splash-foot{margin-top:24px;font-size:10px;color:rgba(255,255,255,0.4);}
.admin-link{display:block;text-align:center;padding:10px;font-size:11px;color:rgba(255,255,255,0.35);cursor:pointer;}

/* AUTH */
.stripe{display:flex;height:5px;}
.stripe div:nth-child(1){flex:1;background:#009e60;}
.stripe div:nth-child(2){flex:1;background:#fcd116;}
.stripe div:nth-child(3){flex:1;background:#3a75c4;}
.auth-top{background:var(--g);padding:28px 20px 36px;}
.auth-back{background:rgba(255,255,255,0.2);border:none;color:#fff;border-radius:8px;padding:7px 14px;font-size:12px;cursor:pointer;margin-bottom:16px;display:inline-block;}
.auth-h{font-size:24px;font-weight:700;color:#fff;}
.auth-s{font-size:12px;color:rgba(255,255,255,0.7);margin-top:4px;}
.auth-body{padding:24px 20px;flex:1;overflow-y:auto;}
.fg{margin-bottom:16px;}
.fg label{font-size:11px;color:var(--muted);display:block;margin-bottom:5px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;}
.fg input,.fg select,.fg textarea{width:100%;padding:12px 14px;border:1.5px solid var(--bd);border-radius:11px;font-size:14px;background:var(--bg2);color:var(--text);outline:none;font-family:inherit;}
.btn-main{width:100%;padding:14px;background:var(--g);color:#fff;font-size:15px;font-weight:700;border:none;border-radius:12px;cursor:pointer;margin-top:8px;}
.btn-main.yellow{background:var(--y);color:#7a5c00;}
.alink{text-align:center;margin-top:14px;font-size:13px;color:var(--muted);}
.alink span{color:var(--g);cursor:pointer;font-weight:600;}
.divider{display:flex;align-items:center;gap:10px;margin:18px 0;color:var(--muted);font-size:12px;}
.divider::before,.divider::after{content:"";flex:1;height:1px;background:var(--bd);}
.motif{display:flex;justify-content:center;gap:5px;padding:14px 0;}
.mb{width:5px;height:22px;border-radius:3px;}

/* HEADER */
.hdr{background:var(--g);padding:16px 16px 52px;position:relative;overflow:hidden;}
.hdr-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.hdr-logo{color:#fff;font-size:22px;font-weight:800;letter-spacing:-0.5px;}
.hdr-flag{display:flex;height:20px;width:30px;border-radius:3px;overflow:hidden;}
.hdr-flag div{flex:1;}
.hdr-loc{font-size:11px;color:rgba(255,255,255,0.75);margin-bottom:12px;}
.uchip{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.15);border-radius:20px;padding:5px 12px 5px 5px;margin-bottom:14px;}
.av-sm{width:24px;height:24px;border-radius:50%;background:var(--y);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;color:#7a5c00;}
.uchip span{font-size:11px;color:#fff;}
.sbox{background:#fff;border-radius:12px;display:flex;align-items:center;gap:8px;padding:10px 14px;position:relative;z-index:2;}
.sbox input{border:none;outline:none;flex:1;font-size:13px;color:var(--text);background:transparent;}
.sbox input::placeholder{color:#bbb;}
.flt-btn{background:var(--g3);border:none;color:var(--g2);border-radius:8px;padding:6px 11px;cursor:pointer;font-size:12px;font-weight:700;}

/* CATS */
.cats{display:flex;gap:8px;overflow-x:auto;padding:14px 14px 0;scrollbar-width:none;}
.cats::-webkit-scrollbar{display:none;}
.cat{flex-shrink:0;padding:8px 13px;border-radius:20px;font-size:12px;cursor:pointer;border:1.5px solid var(--bd);background:var(--bg);color:var(--muted);display:flex;align-items:center;gap:5px;font-weight:500;}
.cat.on{background:var(--y);color:#7a5c00;border-color:var(--y);}

/* FEATURED */
.fstrip{display:flex;gap:10px;overflow-x:auto;padding:0 14px;scrollbar-width:none;}
.fstrip::-webkit-scrollbar{display:none;}
.fc{flex-shrink:0;width:150px;border-radius:13px;overflow:hidden;border:2px solid var(--y);background:var(--bg);cursor:pointer;position:relative;}
.fc-badge{position:absolute;top:7px;right:7px;background:var(--y);color:#7a5c00;font-size:9px;font-weight:800;padding:2px 6px;border-radius:20px;}
.fc-em{height:68px;display:flex;align-items:center;justify-content:center;font-size:30px;background:var(--y3);}
.fc-body{padding:9px;}
.fc-name{font-size:11px;font-weight:700;color:var(--text);margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.fc-cat{font-size:10px;color:var(--muted);}
.fc-stars{font-size:10px;color:#F59E0B;margin-top:2px;}

/* NEWS */
.sh{display:flex;justify-content:space-between;align-items:center;padding:16px 14px 8px;}
.sh-t{font-size:14px;font-weight:700;color:var(--text);}
.see-all{font-size:12px;color:var(--g);cursor:pointer;background:none;border:none;font-weight:600;}
.nstrip{display:flex;gap:10px;overflow-x:auto;padding:0 14px;scrollbar-width:none;}
.nstrip::-webkit-scrollbar{display:none;}
.nc{flex-shrink:0;width:180px;border-radius:12px;overflow:hidden;border:1.5px solid var(--bd);background:var(--bg);cursor:pointer;}
.nc-img{height:76px;display:flex;align-items:center;justify-content:center;font-size:28px;}
.nc-b{padding:9px;}
.nc-tag{font-size:9px;font-weight:700;color:#085041;background:#9FE1CB;padding:2px 6px;border-radius:20px;display:inline-block;margin-bottom:4px;text-transform:uppercase;}
.nc-t{font-size:11px;font-weight:600;color:var(--text);line-height:1.4;}

/* PLACE CARDS */
.plist{padding:0 14px;display:flex;flex-direction:column;gap:10px;}
.pc{background:var(--bg);border:1.5px solid var(--bd);border-radius:14px;overflow:hidden;cursor:pointer;display:flex;}
.pc-th{width:76px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:28px;background:var(--bg2);}
.pc-inf{padding:11px;flex:1;}
.pc-nm{font-size:13px;font-weight:700;color:var(--text);margin-bottom:2px;}
.pc-ct{font-size:10px;color:var(--muted);margin-bottom:5px;}
.pc-mt{display:flex;align-items:center;gap:7px;flex-wrap:wrap;}
.stars{color:#F59E0B;font-size:11px;}
.sct{font-size:10px;color:var(--muted);}
.badge{font-size:9px;padding:2px 7px;border-radius:20px;font-weight:700;}
.badge.open{background:#EAF3DE;color:#3B6D11;}
.badge.bar{background:var(--b3);color:var(--b2);}
.badge.pending{background:#fff3cd;color:#856404;}
.pc-addr{font-size:10px;color:var(--muted);margin-top:3px;}

/* TABBAR */
.tabbar{border-top:1.5px solid var(--bd);display:flex;background:var(--bg);}
.tab{flex:1;padding:10px 0 6px;display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;border:none;background:none;}
.ti{font-size:20px;}
.tl{font-size:9px;color:var(--muted);font-weight:500;}
.tab.on .tl{color:var(--g);font-weight:700;}

/* DETAIL */
.det-top{background:var(--g);padding:16px 16px 18px;}
.det-back{background:rgba(255,255,255,0.2);border:none;color:#fff;border-radius:8px;padding:7px 14px;font-size:12px;cursor:pointer;margin-bottom:10px;font-weight:600;}
.det-sc{flex:1;overflow-y:auto;}
.det-em{font-size:52px;text-align:center;padding:20px;background:var(--bg2);border-radius:14px;margin:0 14px 14px;}
.det-nm{font-size:20px;font-weight:700;color:var(--text);padding:0 14px 3px;}
.det-ct{font-size:13px;color:var(--muted);padding:0 14px 10px;}
.det-st{font-size:18px;color:#F59E0B;padding:0 14px 2px;}
.det-rc{font-size:12px;color:var(--muted);padding:0 14px 14px;}
.infor{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--muted);padding:4px 14px;}
.act-row{display:flex;gap:8px;padding:12px 14px;}
.act-b{flex:1;padding:10px;border:1.5px solid var(--bd);border-radius:10px;background:var(--bg);color:var(--text);font-size:12px;cursor:pointer;text-align:center;font-weight:600;}
.act-b.green{background:var(--g);color:#fff;border-color:var(--g);}
.act-b.yellow{background:var(--y);color:#7a5c00;border-color:var(--y);}
.phg{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:0 14px 4px;}
.phi{aspect-ratio:1;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:32px;background:var(--bg2);}
.rv{border-top:1px solid var(--bd);padding:12px 14px;}
.rv-u{font-size:12px;font-weight:700;color:var(--text);margin-bottom:2px;}
.rv-s{font-size:11px;color:#F59E0B;margin-bottom:4px;}
.rv-t{font-size:12px;color:var(--muted);line-height:1.5;}

/* BAR */
.bar-hero{background:var(--b);padding:22px 16px 44px;}
.bar-t{font-size:22px;font-weight:700;color:#fff;margin-bottom:4px;}
.bar-s{font-size:13px;color:rgba(255,255,255,0.7);}
.bar-bdg{display:inline-block;background:var(--y);color:#7a5c00;font-size:10px;font-weight:700;padding:3px 10px;border-radius:20px;margin-top:8px;}
.bcats{display:flex;gap:8px;overflow-x:auto;padding:12px 14px 0;scrollbar-width:none;}
.bcats::-webkit-scrollbar{display:none;}
.bcat{flex-shrink:0;padding:7px 13px;border-radius:20px;font-size:11px;cursor:pointer;border:1.5px solid var(--bd);background:var(--bg);color:var(--muted);font-weight:500;}
.bcat.on{background:var(--b);color:#fff;border-color:var(--b);}

/* ACTU */
.ac-card{border:1.5px solid var(--bd);border-radius:14px;overflow:hidden;cursor:pointer;margin-bottom:10px;}
.ac-img{height:110px;display:flex;align-items:center;justify-content:center;font-size:40px;}
.ac-body{padding:14px;}
.ac-tag{font-size:9px;font-weight:700;text-transform:uppercase;color:#085041;background:#9FE1CB;padding:2px 7px;border-radius:20px;display:inline-block;margin-bottom:6px;}
.ac-title{font-size:14px;font-weight:700;color:var(--text);margin-bottom:5px;line-height:1.4;}
.ac-txt{font-size:12px;color:var(--muted);line-height:1.6;}
.ac-date{font-size:10px;color:var(--muted);margin-top:6px;}

/* ADD */
.add-top{background:var(--g);padding:22px 16px 28px;}
.add-t{font-size:20px;font-weight:700;color:#fff;margin-bottom:4px;}
.add-s{font-size:12px;color:rgba(255,255,255,0.7);}
.add-body{padding:16px;flex:1;overflow-y:auto;}
.sp-w{display:flex;gap:6px;margin:4px 0;}
.sp{font-size:24px;cursor:pointer;color:#ddd;}
.sp.on{color:#F59E0B;}
.ph-btn{width:100%;padding:26px;border:1.5px dashed var(--bd);border-radius:10px;background:var(--bg2);color:var(--muted);cursor:pointer;font-size:13px;}

/* PROFILE */
.prof-top{background:var(--g);padding:30px 16px 48px;text-align:center;}
.av-lg{width:72px;height:72px;border-radius:50%;background:var(--y);display:flex;align-items:center;justify-content:center;margin:0 auto 10px;font-size:24px;font-weight:800;color:#7a5c00;border:3px solid #fff;}
.prof-nm{font-size:18px;font-weight:700;color:#fff;}
.prof-si{font-size:11px;color:rgba(255,255,255,0.7);margin-top:4px;}
.prof-body{padding:14px;}
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:18px;}
.stat{text-align:center;background:var(--bg2);border-radius:10px;padding:13px;}
.stat-n{font-size:20px;font-weight:800;color:var(--text);}
.stat-l{font-size:9px;color:var(--muted);margin-top:2px;}
.pmenu{display:flex;flex-direction:column;gap:8px;}
.pmi{display:flex;align-items:center;justify-content:space-between;padding:13px 14px;background:var(--bg2);border-radius:10px;cursor:pointer;}
.pmi-l{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--text);font-weight:500;}
.logout{width:100%;padding:13px;background:none;border:1.5px solid var(--red);color:var(--red);border-radius:12px;font-size:14px;cursor:pointer;margin-top:8px;font-weight:600;}
.gbanner{background:var(--y3);border:1.5px solid var(--y);border-radius:10px;padding:10px 14px;margin:10px 14px 0;display:flex;align-items:center;gap:10px;}
.gb-txt{font-size:11px;color:#7a5c00;flex:1;line-height:1.5;}
.gb-btn{background:var(--g);color:#fff;border:none;border-radius:8px;padding:6px 11px;font-size:10px;cursor:pointer;white-space:nowrap;font-weight:700;}

/* MODALS */
.mbg{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:100;align-items:flex-end;justify-content:center;pointer-events:none;visibility:hidden;}
.mbg.on{display:flex;pointer-events:all;visibility:visible;}
.mbox{background:var(--bg);border-radius:20px 20px 0 0;width:100%;max-width:430px;padding:20px 18px 40px;max-height:88vh;overflow-y:auto;}
.mhandle{width:38px;height:4px;background:var(--bd);border-radius:2px;margin:0 auto 18px;}
.mt{font-size:16px;font-weight:700;margin-bottom:16px;color:var(--text);}
.mcancel{width:100%;padding:12px;background:none;border:none;color:var(--muted);font-size:13px;cursor:pointer;margin-top:6px;}

/* TOAST */
.toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:#1a1a1a;color:#fff;padding:10px 20px;border-radius:20px;font-size:13px;font-weight:500;z-index:200;opacity:0;transition:opacity .3s;pointer-events:none;visibility:hidden;white-space:nowrap;}
.toast.show{opacity:1;visibility:visible;}
</style>
</head>
<body>
<div class="app">

<div class="toast" id="toast"></div>

<!-- SPLASH -->
<div class="screen on" id="s-splash">
  <div class="splash">
    <div class="flag"><div style="background:#009e60"></div><div style="background:#fcd116"></div><div style="background:#3a75c4"></div></div>
    <div class="logo-big">MBOLO</div>
    <div class="logo-sub">Guide de Libreville</div>
    <div class="sdots"><div class="sdot y"></div><div class="sdot"></div><div class="sdot y"></div><div class="sdot"></div><div class="sdot y"></div></div>
    <div style="width:100%">
      <button class="btn-y" onclick="go('s-register')">Créer un compte</button>
      <button class="btn-wh" onclick="go('s-login')">Se connecter</button>
      <button class="btn-ghost" onclick="goGuest()">Parcourir sans compte →</button>
    </div>
    <div class="splash-foot">🇬🇦 Fait avec fierté pour Libreville</div>
    <span class="admin-link" onclick="goAdmin()">⚙️ Admin</span>
  </div>
</div>

<!-- LOGIN -->
<div class="screen" id="s-login">
  <div class="stripe"><div></div><div></div><div></div></div>
  <div class="auth-top">
    <button class="auth-back" onclick="go('s-splash')">← Retour</button>
    <div class="auth-h">Connexion</div>
    <div class="auth-s">Bon retour sur MBOLO 🇬🇦</div>
  </div>
  <div class="auth-body">
    <div class="fg"><label>Email</label><input type="email" id="li-email" placeholder="votre@email.com"/></div>
    <div class="fg"><label>Mot de passe</label><input type="password" id="li-pwd" placeholder="••••••••"/></div>
    <button class="btn-main" onclick="doLogin()">Se connecter</button>
    <div class="divider">ou</div>
    <div class="alink">Pas de compte ? <span onclick="go('s-register')">Créer un compte</span></div>
    <div class="alink" style="margin-top:8px"><span onclick="goGuest()">Continuer sans compte →</span></div>
  </div>
</div>

<!-- REGISTER -->
<div class="screen" id="s-register">
  <div class="stripe"><div></div><div></div><div></div></div>
  <div class="auth-top">
    <button class="auth-back" onclick="go('s-splash')">← Retour</button>
    <div class="auth-h">Créer un compte</div>
    <div class="auth-s">Rejoignez la communauté MBOLO</div>
  </div>
  <div class="auth-body">
    <div class="fg"><label>Prénom et Nom</label><input type="text" id="rg-name" placeholder="ex: Amina Ngoubili"/></div>
    <div class="fg"><label>Email</label><input type="email" id="rg-email" placeholder="votre@email.com"/></div>
    <div class="fg"><label>Téléphone (optionnel)</label><input type="tel" id="rg-phone" placeholder="+241 06 ..."/></div>
    <div class="fg"><label>Mot de passe</label><input type="password" id="rg-pwd" placeholder="Min. 8 caractères"/></div>
    <div class="motif">
      <div class="mb" style="background:#009e60"></div><div class="mb" style="background:#fcd116"></div><div class="mb" style="background:#3a75c4"></div>
      <div class="mb" style="background:#009e60"></div><div class="mb" style="background:#fcd116"></div><div class="mb" style="background:#3a75c4"></div>
    </div>
    <button class="btn-main yellow" onclick="doRegister()">Créer mon compte</button>
    <div class="alink" style="margin-top:12px">Déjà membre ? <span onclick="go('s-login')">Se connecter</span></div>
    <div class="alink" style="margin-top:8px"><span onclick="goGuest()">Continuer sans compte →</span></div>
  </div>
</div>

<!-- MAIN -->
<div class="screen" id="s-main">
  <div class="scroll" id="mainScroll"></div>
  <div class="tabbar">
    <button class="tab on" id="tab-home" onclick="switchTab('home')"><span class="ti">🏠</span><span class="tl">Accueil</span></button>
    <button class="tab" id="tab-bar" onclick="switchTab('bar')"><span class="ti">🍹</span><span class="tl">Bar</span></button>
    <button class="tab" id="tab-actu" onclick="switchTab('actu')"><span class="ti">📰</span><span class="tl">Actualités</span></button>
    <button class="tab" id="tab-add" onclick="switchTab('add')"><span class="ti">➕</span><span class="tl">Ajouter</span></button>
    <button class="tab" id="tab-prof" onclick="switchTab('prof')"><span class="ti">👤</span><span class="tl">Profil</span></button>
  </div>
</div>

<!-- DETAIL -->
<div class="screen" id="s-detail">
  <div class="det-top"><button class="det-back" onclick="go('s-main')">← Retour</button></div>
  <div class="det-sc">
    <div class="det-em" id="d-em"></div>
    <div class="det-nm" id="d-nm"></div>
    <div class="det-ct" id="d-ct"></div>
    <div class="det-st" id="d-st"></div>
    <div class="det-rc" id="d-rc"></div>
    <div class="infor"><span>📍</span><span id="d-ad"></span></div>
    <div class="infor"><span>🕐</span><span id="d-hr"></span></div>
    <div class="infor"><span>📞</span><span id="d-ph"></span></div>
    <div class="act-row">
      <button class="act-b yellow" onclick="openReview()">★ Avis</button>
      <button class="act-b" onclick="toast('Lien copie !')">↗ Partager</button>
      <button class="act-b green" onclick="toast('Navigation lancee...')">🗺 Y aller</button>
    </div>
    <div style="padding:0 14px;font-size:13px;font-weight:700;color:var(--text);margin-bottom:8px">Photos</div>
    <div class="phg" id="d-photos"></div>
