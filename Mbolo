  {id:7,em:"🌊",name:"Plage des Cocotiers",cat:"Loisirs",quartier:"Corniche",addr:"Corniche de Libreville",phone:"-",hours:"Ouvert toute la journee",rating:4.4,reviews:305,open:true,status:"approved",submittedBy:"Admin",submittedAt:"01/01/2025",photos:["🌴","🌊","🏄","🌅"],avis:[{user:"Ibrahim D.",stars:5,txt:"La plus belle plage de Libreville !"},{user:"Nadia L.",stars:4,txt:"Tres belle plage."}]},
  {id:8,em:"🍹",name:"Bar Le Panthere",cat:"Bar",quartier:"Plateau",addr:"Plateau, Quartier Glass",phone:"+241 01 77 66 55",hours:"Mer-Dim 18h-03h",rating:4.6,reviews:156,open:true,status:"approved",submittedBy:"Admin",submittedAt:"01/01/2025",photos:["🍸","🎸","🪩","🌃"],avis:[{user:"Guy-Roger E.",stars:5,txt:"Le meilleur bar du Plateau !"},{user:"Brice M.",stars:5,txt:"Ambiance electrique le vendredi soir."}]},
  {id:9,em:"🍽️",name:"Chez Jeannot",cat:"Restaurant",quartier:"Louis",addr:"Quartier Louis",phone:"+241 06 11 22 33",hours:"Lun-Sam 12h-22h",rating:4.3,reviews:89,open:true,status:"approved",submittedBy:"Admin",submittedAt:"01/01/2025",photos:["🍗","🥗","🍜","🥘"],avis:[{user:"Regine M.",stars:4,txt:"Cuisine traditionnelle authentique !"},{user:"Armel B.",stars:5,txt:"Le meilleur poulet braise de Libreville."}]}
];

var DEFAULT_ACTUS=[
  {id:1,img:"🎵",bg:"#E1F5EE",tag:"Evenement",title:"Festival Gabao 2025",txt:"Le Festival Gabao revient avec une programmation exceptionnelle. Les artistes de toute Afrique centrale seront presents.",date:"15 mars 2025"},
  {id:2,img:"🏗️",bg:"#fff8d6",tag:"Infra",title:"Nouveau boulevard bord de mer inaugure",txt:"Le nouveau boulevard de la Corniche est officiellement ouvert, redonnant a Libreville son visage maritime.",date:"10 mars 2025"},
  {id:3,img:"🌊",bg:"#e8f0fb",tag:"Sortie",title:"Top 5 spots plage ce week-end",txt:"Profitez du beau temps sur les plus belles plages de Libreville. La Plage des Cocotiers est au meilleur niveau.",date:"8 mars 2025"},
  {id:4,img:"🍹",bg:"#FAECE7",tag:"Bar",title:"Les bars du Plateau ouvrent tot",txt:"Ce week-end, plusieurs bars du Plateau ouvrent des 15h. Le Bar Le Panthere propose des cocktails speciaux.",date:"5 mars 2025"},
  {id:5,img:"🏛️",bg:"#EAF3DE",tag:"Culture",title:"Musee National : nouvelle exposition",txt:"Une nouvelle exposition sur l'histoire du Gabon a ouvert ses portes. Entree gratuite le week-end.",date:"1 mars 2025"}
];

function loadData(){
  try{
    var p=localStorage.getItem("mbolo_places");
    var a=localStorage.getItem("mbolo_actus");
    return {places:p?JSON.parse(p):JSON.parse(JSON.stringify(DEFAULT_PLACES)), actus:a?JSON.parse(a):JSON.parse(JSON.stringify(DEFAULT_ACTUS))};
  }catch(e){return {places:JSON.parse(JSON.stringify(DEFAULT_PLACES)),actus:JSON.parse(JSON.stringify(DEFAULT_ACTUS))};}
}
function saveData(){
  try{localStorage.setItem("mbolo_places",JSON.stringify(places));localStorage.setItem("mbolo_actus",JSON.stringify(actus));}catch(e){}
}

var data=loadData();
var places=data.places;
var actus=data.actus;

function getFeaturedIds(){try{var f=localStorage.getItem("mbolo_featured");return f?JSON.parse(f):[];}catch(e){return [];}}

function stH(n){var r=Math.round(n);return "★".repeat(r)+"☆".repeat(5-r);}

function toast(msg){
  var t=document.getElementById("toast");
  t.textContent=msg;t.classList.add("show");
  setTimeout(function(){t.classList.remove("show");},2500);
}

function go(id){
  document.querySelectorAll(".screen").forEach(function(s){s.classList.remove("on");});
  document.getElementById(id).classList.add("on");
}

function closeModal(id){document.getElementById(id).classList.remove("on");}
function goGuest(){isGuest=true;currentUser={name:"Visiteur",guest:true};go("s-main");switchTab("home");}

function goAdmin(){
  document.getElementById("adm-user").value="";
  document.getElementById("adm-pass").value="";
  document.getElementById("adminModal").classList.add("on");
}

function doAdminLogin(){
  var u=document.getElementById("adm-user").value.trim();
  var p=document.getElementById("adm-pass").value.trim();
  var ok={admin:"mbolo2025",superadmin:"gabon2025"};
  if(ok[u]&&ok[u]===p){closeModal("adminModal");window.location.href="mbolo-admin.html";}
  else{toast("Code incorrect.");}
}

function doLogin(){
  var e=document.getElementById("li-email").value.trim();
  if(!e){alert("Email requis.");return;}
  currentUser={name:e.split("@")[0]||"Utilisateur",email:e,guest:false};
  isGuest=false;go("s-main");switchTab("home");
}

function doRegister(){
  var n=document.getElementById("rg-name").value.trim();
  var e=document.getElementById("rg-email").value.trim();
  var ph=document.getElementById("rg-phone").value.trim();
  if(!n||!e){alert("Nom et email requis.");return;}
  currentUser={name:n,email:e,guest:false};
  isGuest=false;
  try{
    var users=JSON.parse(localStorage.getItem("mbolo_users")||"[]");
    if(!users.find(function(u){return u.email===e;})){
      users.push({id:Date.now(),name:n,email:e,phone:ph||"Non renseigne",joinDate:new Date().toLocaleDateString("fr-FR"),places:0,reviews:0,status:"active"});
      localStorage.setItem("mbolo_users",JSON.stringify(users));
    }
  }catch(ex){}
  go("s-main");switchTab("home");toast("Bienvenue sur MBOLO, "+n+" !");
}

function switchTab(t){
  document.querySelectorAll(".tab").forEach(function(x){x.classList.remove("on");});
  var el=document.getElementById("tab-"+t);
  if(el)el.classList.add("on");
  var map={home:renderHome,bar:renderBar,actu:renderActu,add:renderAdd,prof:renderProf};
  if(map[t])map[t]();
}

function buildFeaturedSection(){
  var ids=getFeaturedIds();
  if(!ids.length)return "";
  var fps=ids.map(function(id){return places.find(function(p){return p.id===id&&p.status!=="suspended";});}).filter(Boolean);
  if(!fps.length)return "";
  var cards=fps.map(function(p){
    return '<div class="fc" onclick="openPlace('+p.id+')">'
      +'<div class="fc-badge">Vedette</div>'
      +'<div class="fc-em">'+p.em+'</div>'
      +'<div class="fc-body">'
      +'<div class="fc-name">'+p.name+'</div>'
      +'<div class="fc-cat">'+p.cat+'</div>'
      +'<div class="fc-stars">'+stH(p.rating)+' '+p.rating+'</div>'
      +'</div></div>';
  }).join("");
  return '<div class="sh"><span class="sh-t">⭐ Mis en avant</span>'
    +'<span style="font-size:10px;color:var(--y2);font-weight:700;background:var(--y3);padding:3px 9px;border-radius:20px">Selection MBOLO</span></div>'
    +'<div class="fstrip">'+cards+'</div>';
}

function renderHome(){
  var un=currentUser?currentUser.name:"Visiteur";
  var initials=un.substring(0,2).toUpperCase();
  var guestBanner=isGuest?'<div class="gbanner"><span style="font-size:18px">🇬🇦</span><div class="gb-txt">Mode visiteur. Creez un compte pour publier.</div><button class="gb-btn" onclick="go(\'s-register\')">Rejoindre</button></div>':"";
  var newsCards=actus.slice(0,4).map(function(a){
    return '<div class="nc" onclick="switchTab(\'actu\')"><div class="nc-img" style="background:'+a.bg+'">'+a.img+'</div><div class="nc-b"><div class="nc-tag">'+a.tag+'</div><div class="nc-t">'+a.title+'</div></div></div>';
  }).join("");
  document.getElementById("mainScroll").innerHTML=guestBanner
    +'<div class="hdr">'
    +'<div class="hdr-row"><div class="hdr-logo">MBOLO</div>'
    +'<div style="display:flex;gap:8px;align-items:center"><div class="hdr-flag"><div style="background:#009e60"></div><div style="background:#fcd116"></div><div style="background:#3a75c4"></div></div></div></div>'
    +'<div class="hdr-loc">📍 Libreville, Gabon</div>'
    +'<div class="uchip"><div class="av-sm">'+initials+'</div><span>'+un+'</span></div>'
    +'<div class="sbox"><span style="font-size:15px;color:#bbb">🔍</span><input type="text" id="searchInput" placeholder="Restaurant, bar, hotel..." oninput="renderPlaces()"/><button class="flt-btn">Filtrer</button></div>'
    +'</div>'
    +'<div class="cats" id="catStrip"></div>'
    +buildFeaturedSection()
    +'<div class="sh"><span class="sh-t">Actualites Libreville</span><button class="see-all" onclick="switchTab(\'actu\')">Tout voir</button></div>'
    +'<div class="nstrip">'+newsCards+'</div>'
    +'<div class="sh"><span class="sh-t">Etablissements</span></div>'
    +'<div class="plist" id="placeList"></div>'
    +'<div style="height:88px"></div>';
  renderCats();
  renderPlaces();
}

function renderCats(){
  var s=document.getElementById("catStrip");
  if(!s)return;
  s.innerHTML=CATS.map(function(c){
    return '<div class="cat'+(c.l===currentCat?" on":"")+'" onclick="filterCat(\''+c.l+'\')"><span>'+c.i+'</span> '+c.l+'</div>';
  }).join("");
}

function filterCat(cat){currentCat=cat;renderCats();renderPlaces();}

function renderPlaces(){
  var q=(document.getElementById("searchInput")||{}).value||"";
  var list=document.getElementById("placeList");
  if(!list)return;
  var filtered=places.filter(function(p){
    if(p.status==="suspended")return false;
    var mc=currentCat==="Tous"||p.cat===currentCat;
    var mq=!q||p.name.toLowerCase().includes(q.toLowerCase())||p.addr.toLowerCase().includes(q.toLowerCase())||(p.quartier||"").toLowerCase().includes(q.toLowerCase());
    return mc&&mq;
  });
  if(!filtered.length){list.innerHTML='<div style="text-align:center;padding:28px;color:var(--muted);font-size:13px">Aucun resultat</div>';return;}
  var featIds=getFeaturedIds();
  list.innerHTML=filtered.map(function(p){
    var isFeat=featIds.includes(p.id);
    return '<div class="pc" onclick="openPlace('+p.id+')">'
      +'<div class="pc-th">'+p.em+'</div>'
      +'<div class="pc-inf">'
      +'<div class="pc-nm">'+p.name+(isFeat?' <span style="font-size:9px;background:var(--y3);color:var(--y2);padding:2px 6px;border-radius:20px;font-weight:700">⭐</span>':'')+(p.status==="pending"?' <span class="badge pending">En attente</span>':'')+'</div>'
      +'<div class="pc-ct">'+p.cat+' · '+(p.quartier||'')+'</div>'
      +'<div class="pc-mt"><span class="stars">'+stH(p.rating)+'</span><span class="sct">'+p.rating+' ('+p.reviews+')</span>'+(p.open?'<span class="badge open">Ouvert</span>':'')+(p.cat==="Bar"?'<span class="badge bar">Bar</span>':'')+'</div>'
      +'<div class="pc-addr">📍 '+p.addr+'</div>'
      +'</div></div>';
  }).join("");
}

function openPlace(id){
  var p=places.find(function(x){return x.id===id;});
  if(!p)return;
  currentPlaceId=id;
  document.getElementById("d-em").textContent=p.em;
  document.getElementById("d-nm").textContent=p.name;
  document.getElementById("d-ct").textContent=p.cat+" · "+(p.quartier||"");
  document.getElementById("d-st").textContent=stH(p.rating)+" "+p.rating;
  document.getElementById("d-rc").textContent=p.reviews+" avis";
  document.getElementById("d-ad").textContent=p.addr;
  document.getElementById("d-hr").textContent=p.hours;
  document.getElementById("d-ph").textContent=p.phone;
  document.getElementById("d-photos").innerHTML=(p.photos||[]).map(function(ph){return '<div class="phi">'+ph+'</div>';}).join("");
  var avis=p.avis||[];
  document.getElementById("d-reviews").innerHTML=avis.length
    ?avis.map(function(a){return '<div class="rv"><div class="rv-u">'+a.user+'</div><div class="rv-s">'+stH(a.stars)+'</div><div class="rv-t">'+a.txt+'</div></div>';}).join("")
    :'<div style="padding:14px;font-size:12px;color:var(--muted)">Aucun avis pour le moment.</div>';
  go("s-detail");
}

function openReview(){
  if(!currentUser||isGuest){document.getElementById("mustRegModal").classList.add("on");return;}
  revStar=0;
  document.getElementById("revTxt").value="";
  document.querySelectorAll("#revStars .sp").forEach(function(s){s.classList.remove("on");});
  document.getElementById("reviewModal").classList.add("on");
}

function setStar(n){
  revStar=n;
  document.querySelectorAll("#revStars .sp").forEach(function(s,i){s.classList.toggle("on",i<n);});
}

function submitReview(){
  var txt=document.getElementById("revTxt").value.trim();
  if(!txt||!revStar){alert("Note et commentaire requis.");return;}
  var p=places.find(function(x){return x.id===currentPlaceId;});
  if(!p)return;
  if(!p.avis)p.avis=[];
  p.avis.unshift({user:currentUser.name,stars:revStar,txt:txt});
  p.reviews++;
  p.rating=Math.round((p.rating*(p.reviews-1)+revStar)/p.reviews*10)/10;
  userReviews++;
  try{
    var users=JSON.parse(localStorage.getItem("mbolo_users")||"[]");
    var u=users.find(function(x){return x.email===currentUser.email;});
    if(u){u.reviews=(u.reviews||0)+1;localStorage.setItem("mbolo_users",JSON.stringify(users));}
  }catch(ex){}
  saveData();
  closeModal("reviewModal");
  openPlace(currentPlaceId);
  toast("Votre avis a ete publie !");
}

function renderBar(){
  var bars=places.filter(function(p){return p.cat==="Bar"&&p.status!=="suspended";});
  var cards=bars.map(function(p){
    return '<div class="pc" onclick="openPlace('+p.id+')">'
      +'<div class="pc-th" style="background:#e8f0fb">'+p.em+'</div>'
      +'<div class="pc-inf"><div class="pc-nm">'+p.name+'</div>'
      +'<div class="pc-ct">'+p.addr+'</div>'
      +'<div class="pc-mt"><span class="stars">'+stH(p.rating)+'</span><span class="sct">'+p.rating+' ('+p.reviews+')</span>'+(p.open?'<span class="badge open">Ouvert</span>':'')+'</div>'
      +'<div class="pc-addr">🕐 '+p.hours+'</div></div></div>';
  }).join("");
  document.getElementById("mainScroll").innerHTML=
    '<div class="bar-hero"><div class="bar-t">Bars et Boissons 🍹</div><div class="bar-s">Tous les bars de Libreville</div><div class="bar-bdg">'+bars.length+' bars references</div></div>'
    +'<div class="bcats"><div class="bcat on">Tous</div><div class="bcat">Cocktails</div><div class="bcat">Biere locale</div><div class="bcat">Terrasse</div><div class="bcat">Musique live</div></div>'
    +'<div class="sh"><span class="sh-t">Bars populaires</span></div>'
    +'<div class="plist">'+cards+'</div>'
    +'<div style="height:88px"></div>';
  document.querySelectorAll(".bcat").forEach(function(bc){
    bc.onclick=function(){document.querySelectorAll(".bcat").forEach(function(x){x.classList.remove("on");});this.classList.add("on");};
  });
}

function renderActu(){
  var newsHTML=actus.map(function(a){
    return '<div class="ac-card"><div class="ac-img" style="background:'+a.bg+'">'+a.img+'</div>'
      +'<div class="ac-body"><div class="ac-tag">'+a.tag+'</div><div class="ac-title">'+a.title+'</div>'
      +'<div class="ac-txt">'+a.txt+'</div><div class="ac-date">📅 '+a.date+'</div></div></div>';
  }).join("");
  var newPlaces=places.filter(function(p){return p.status==="approved";});
  var placesHTML=newPlaces.length?newPlaces.map(function(p){
    return '<div class="ac-card" onclick="openPlace('+p.id+')" style="cursor:pointer">'
      +'<div style="padding:14px;display:flex;align-items:center;gap:14px">'
      +'<div style="font-size:40px">'+p.em+'</div>'
      +'<div style="flex:1"><div style="display:flex;gap:6px;margin-bottom:4px"><span class="ac-tag">Nouveau</span></div>'
      +'<div style="font-size:14px;font-weight:700;color:var(--text)">'+p.name+'</div>'
      +'<div style="font-size:11px;color:var(--muted)">📍 '+p.quartier+' — '+p.addr+'</div>'
      +(p.submittedBy&&p.submittedBy!=="Admin"?'<div style="font-size:10px;color:var(--g);margin-top:3px;font-weight:600">Ajoute par '+p.submittedBy+'</div>':"")
      +'</div></div></div>';
  }).join(""):'<div style="text-align:center;padding:40px 20px;color:var(--muted);font-size:13px">Aucun lieu pour le moment.</div>';
  document.getElementById("mainScroll").innerHTML=
    '<div class="hdr" style="padding-bottom:18px">'
    +'<div class="hdr-row"><div class="hdr-logo">Actualites 📰</div>'
    +'<div class="hdr-flag"><div style="background:#009e60"></div><div style="background:#fcd116"></div><div style="background:#3a75c4"></div></div></div>'
    +'<div class="hdr-loc">📍 Libreville, Gabon</div></div>'
    +'<div style="display:flex;gap:6px;padding:14px 14px 0">'
    +'<button id="at-news" onclick="showActuTab(\'news\')" style="flex:1;padding:9px;border-radius:10px;border:1.5px solid var(--g);background:var(--g);color:#fff;font-size:12px;font-weight:700;cursor:pointer">📰 Actualites</button>'
    +'<button id="at-places" onclick="showActuTab(\'places\')" style="flex:1;padding:9px;border-radius:10px;border:1.5px solid var(--bd);background:var(--bg);color:var(--muted);font-size:12px;font-weight:700;cursor:pointer">📍 Nouveaux lieux</button>'
    +'</div>'
    +'<div id="ap-news" style="padding:12px 14px 0">'+newsHTML+'</div>'
    +'<div id="ap-places" style="display:none;padding:12px 14px 0">'+placesHTML+'</div>'
    +'<div style="height:88px"></div>';
}

function showActuTab(tab){
  document.getElementById("ap-news").style.display=tab==="news"?"block":"none";
  document.getElementById("ap-places").style.display=tab==="places"?"block":"none";
  var bn=document.getElementById("at-news");
  var bp=document.getElementById("at-places");
  if(tab==="news"){bn.style.cssText="flex:1;padding:9px;border-radius:10px;border:1.5px solid var(--g);background:var(--g);color:#fff;font-size:12px;font-weight:700;cursor:pointer";bp.style.cssText="flex:1;padding:9px;border-radius:10px;border:1.5px solid var(--bd);background:var(--bg);color:var(--muted);font-size:12px;font-weight:700;cursor:pointer";}
  else{bp.style.cssText="flex:1;padding:9px;border-radius:10px;border:1.5px solid var(--g);background:var(--g);color:#fff;font-size:12px;font-weight:700;cursor:pointer";bn.style.cssText="flex:1;padding:9px;border-radius:10px;border:1.5px solid var(--bd);background:var(--bg);color:var(--muted);font-size:12px;font-weight:700;cursor:pointer";}
}

function renderAdd(){
  if(isGuest){
    document.getElementById("mainScroll").innerHTML=
      '<div style="text-align:center;padding:70px 24px">'
      +'<div style="font-size:48px;margin-bottom:16px">🔒</div>'
      +'<div style="font-size:17px;font-weight:700;color:var(--text);margin-bottom:8px">Connexion requise</div>'
      +'<div style="font-size:13px;color:var(--muted);margin-bottom:24px;line-height:1.6">Creez un compte pour ajouter des etablissements.</div>'
      +'<button class="btn-main" style="max-width:270px;margin:0 auto;display:block" onclick="go(\'s-register\')">Creer un compte gratuit</button>'
      +'<div class="alink" style="margin-top:12px"><span onclick="go(\'s-login\')">Deja membre ? Se connecter</span></div>'
      +'</div><div style="height:88px"></div>';
    return;
  }
  document.getElementById("mainScroll").innerHTML=
    '<div class="add-top"><div class="add-t">Ajouter un lieu</div><div class="add-s">Partagez une adresse avec la communaute</div></div>'
    +'<div class="stripe"><div></div><div></div><div></div></div>'
    +'<div class="add-body">'
    +'<div style="background:#fff8d6;border:1px solid #fcd116;border-radius:10px;padding:10px 14px;margin-bottom:16px;font-size:12px;color:#7a5c00">Votre etablissement sera soumis a validation avant publication.</div>'
    +'<div class="fg"><label>Nom *</label><input type="text" id="newName" placeholder="Ex: Restaurant Le Perroquet"/></div>'
    +'<div class="fg"><label>Categorie *</label><select id="newCat"><option>Restaurant</option><option>Bar</option><option>Hotel</option><option>Shopping</option><option>Sante</option><option>Loisirs</option><option>Autre</option></select></div>'
    +'<div class="fg"><label>Quartier *</label><input type="text" id="newQrt" placeholder="Ex: Plateau, Louis, Akanda..."/></div>'
    +'<div class="fg"><label>Adresse *</label><input type="text" id="newAddr" placeholder="Ex: Face au marche Mont-Bouet"/></div>'
    +'<div class="fg"><label>Telephone</label><input type="tel" id="newPhone" placeholder="+241 06 ..."/></div>'
    +'<div class="fg"><label>Horaires</label><input type="text" id="newHours" placeholder="Ex: Lun-Sam 08h-22h"/></div>'
    +'<div class="fg"><label>Note initiale</label><div class="sp-w" id="addStars"><span class="sp" onclick="setAddStar(1)">★</span><span class="sp" onclick="setAddStar(2)">★</span><span class="sp" onclick="setAddStar(3)">★</span><span class="sp" onclick="setAddStar(4)">★</span><span class="sp" onclick="setAddStar(5)">★</span></div></div>'
    +'<button class="btn-main yellow" onclick="submitPlace()">Soumettre pour validation</button>'
    +'</div><div style="height:88px"></div>';
}

function setAddStar(n){addStar=n;document.querySelectorAll("#addStars .sp").forEach(function(s,i){s.classList.toggle("on",i<n);});}

function submitPlace(){
  var name=(document.getElementById("newName")||{}).value||"";
  var addr=(document.getElementById("newAddr")||{}).value||"";
  var qrt=(document.getElementById("newQrt")||{}).value||"";
  var cat=(document.getElementById("newCat")||{}).value||"Restaurant";
  if(!name.trim()||!addr.trim()||!qrt.trim()){alert("Nom, quartier et adresse sont requis.");return;}
  var icons={Restaurant:"🍽️",Bar:"🍹",Hotel:"🏨",Shopping:"🛍️",Sante:"🏥",Loisirs:"🌊",Autre:"📍"};
  var newPlace={id:Date.now(),em:icons[cat]||"📍",name:name.trim(),cat:cat,quartier:qrt.trim(),addr:addr.trim(),
    phone:(document.getElementById("newPhone")||{}).value||"-",hours:(document.getElementById("newHours")||{}).value||"-",
    rating:addStar||0,reviews:0,open:true,status:"pending",submittedBy:currentUser.name,submittedAt:new Date().toLocaleDateString("fr-FR"),photos:["📷"],avis:[]};
  places.unshift(newPlace);userPlaces++;addStar=0;
  try{var users=JSON.parse(localStorage.getItem("mbolo_users")||"[]");var u=users.find(function(x){return x.email===currentUser.email;});if(u){u.places=(u.places||0)+1;localStorage.setItem("mbolo_users",JSON.stringify(users));}}catch(ex){}
  saveData();
  toast("Soumis ! En attente de validation.");
  switchTab("home");
}

function renderProf(){
  var un=currentUser?currentUser.name:"Visiteur";
  var em=currentUser&&currentUser.email?currentUser.email:"";
  var initials=un.substring(0,2).toUpperCase();
  var body="";
  if(isGuest){
    body='<div style="background:var(--y3);border:1.5px solid var(--y);border-radius:12px;padding:18px;text-align:center;margin-bottom:16px">'
      +'<div style="font-size:14px;font-weight:700;color:#7a5c00;margin-bottom:6px">Rejoignez la communaute MBOLO 🇬🇦</div>'
      +'<div style="font-size:12px;color:#7a5c00;margin-bottom:14px">Publiez des avis et ajoutez des lieux.</div>'
      +'<button class="btn-main" style="max-width:200px;margin:0 auto;display:block" onclick="go(\'s-register\')">Creer un compte</button>'
      +'<div class="alink" style="margin-top:10px"><span onclick="go(\'s-login\')">Se connecter</span></div>'
      +'</div>';
  } else {
    body='<div style="background:var(--bg2);border-radius:10px;padding:13px 14px;margin-bottom:8px">'
      +'<div style="font-size:10px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px">Mon compte</div>'
      +'<div style="font-size:13px;font-weight:700;color:var(--text)">'+un+'</div>'
      +(em?'<div style="font-size:12px;color:var(--muted);margin-top:2px">'+em+'</div>':"")
      +'</div>'
      +'<div class="pmenu">'
      +'<div class="pmi" onclick="showMyReviews()"><div class="pmi-l"><span style="font-size:16px">💬</span> Mes avis publies</div><span style="color:var(--muted)">›</span></div>'
      +'<div class="pmi" onclick="showMyPlaces()"><div class="pmi-l"><span style="font-size:16px">📍</span> Mes lieux ajoutes</div><span style="color:var(--muted)">›</span></div>'
      +'<div class="pmi" onclick="toast(\'Fonctionnalite bientot disponible\')"><div class="pmi-l"><span style="font-size:16px">🔔</span> Notifications</div><span style="color:var(--muted)">›</span></div>'
      +'<button class="logout" onclick="logout()">Se deconnecter</button>'
      +'</div>';
  }
  document.getElementById("mainScroll").innerHTML=
    '<div class="prof-top"><div class="av-lg">'+initials+'</div>'
    +'<div class="prof-nm">'+un+'</div>'
    +'<div class="prof-si">'+(isGuest?"Mode visiteur":"Membre MBOLO 🇬🇦")+'</div></div>'
    +'<div class="stripe"><div></div><div></div><div></div></div>'
    +'<div class="prof-body">'
    +'<div class="stats">'
    +'<div class="stat"><div class="stat-n">'+userPlaces+'</div><div class="stat-l">Ajoutes</div></div>'
    +'<div class="stat"><div class="stat-n">'+userReviews+'</div><div class="stat-l">Avis</div></div>'
    +'<div class="stat"><div class="stat-n">🇬🇦</div><div class="stat-l">Libreville</div></div>'
    +'</div>'+body+'</div>'
    +'<div style="height:88px"></div>';
}

function showMyReviews(){
  var reviews=[];
  places.forEach(function(p){(p.avis||[]).filter(function(a){return a.user===currentUser.name;}).forEach(function(a){reviews.push({place:p,avis:a});});});
  if(!reviews.length){toast("Vous n avez pas encore publie d avis.");return;}
  var html='<div style="padding:14px"><button onclick="switchTab(\'prof\')" style="background:none;border:none;color:var(--g);font-size:13px;cursor:pointer;font-weight:700;margin-bottom:14px">← Retour au profil</button>'
    +'<div style="font-size:16px;font-weight:700;color:var(--text);margin-bottom:14px">Mes avis ('+reviews.length+')</div>';
  reviews.forEach(function(r){
    html+='<div style="border:1.5px solid var(--bd);border-radius:12px;padding:13px;margin-bottom:10px;cursor:pointer" onclick="openPlace('+r.place.id+')">'
      +'<div style="display:flex;align-items:center;gap:10px;margin-bottom:7px"><span style="font-size:22px">'+r.place.em+'</span>'
      +'<div><div style="font-size:13px;font-weight:700;color:var(--text)">'+r.place.name+'</div></div></div>'
      +'<div style="color:#F59E0B;font-size:12px;margin-bottom:4px">'+stH(r.avis.stars)+'</div>'
      +'<div style="font-size:12px;color:var(--muted)">'+r.avis.txt+'</div></div>';
  });
  html+='</div><div style="height:88px"></div>';
  document.getElementById("mainScroll").innerHTML=html;
}

function showMyPlaces(){
  var mine=places.filter(function(p){return p.submittedBy===currentUser.name;});
  if(!mine.length){toast("Vous n avez pas encore ajoute de lieu.");return;}
  var html='<div style="padding:14px"><button onclick="switchTab(\'prof\')" style="background:none;border:none;color:var(--g);font-size:13px;cursor:pointer;font-weight:700;margin-bottom:14px">← Retour au profil</button>'
    +'<div style="font-size:16px;font-weight:700;color:var(--text);margin-bottom:14px">Mes lieux ('+mine.length+')</div>';
  mine.forEach(function(p){
    var sc=p.status==="approved"?"background:#EAF3DE;color:#3B6D11":p.status==="pending"?"background:#fff3cd;color:#856404":"background:rgba(226,75,74,0.1);color:#E24B4A";
    var sl=p.status==="approved"?"Approuve":p.status==="pending"?"En attente":"Suspendu";
    html+='<div style="border:1.5px solid var(--bd);border-radius:12px;overflow:hidden;display:flex;cursor:pointer;margin-bottom:10px" onclick="openPlace('+p.id+')">'
      +'<div style="width:64px;display:flex;align-items:center;justify-content:center;font-size:26px;background:var(--bg2)">'+p.em+'</div>'
      +'<div style="padding:10px;flex:1"><div style="font-size:13px;font-weight:700;color:var(--text);margin-bottom:3px">'+p.name+'</div>'
      +'<div style="font-size:11px;color:var(--muted);margin-bottom:5px">'+p.cat+' · '+(p.quartier||"")+'</div>'
      +'<span style="font-size:9px;padding:2px 8px;border-radius:20px;font-weight:700;'+sc+'">'+sl+'</span>'
      +'</div></div>';
  });
  html+='</div><div style="height:88px"></div>';
  document.getElementById("mainScroll").innerHTML=html;
}

function logout(){if(!confirm("Se deconnecter ?"))return;isGuest=false;currentUser=null;go("s-splash");}
</script>
</body>
</html>
